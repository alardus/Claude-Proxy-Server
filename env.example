# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Configuration (опционально, если используете OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Proxy Server Configuration
PROXY_BASE_URL=http://localhost:8000
PROXY_API_KEY=your_generated_proxy_api_key_here

# Admin Panel Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# Debug Mode (опционально, для детального логирования)
# DEBUG_MODE=true

# Используйте generate_api_key.py для генерации безопасного PROXY_API_KEY

# Deploy configuration (used by deploy.sh)
DEPLOY_DOMAIN='your.domain.com'
DEPLOY_UPSTREAM_PORT='7070'
DEPLOY_SSL_SOURCE_HOST='user@your-cert-server'
DEPLOY_SSL_SOURCE_CERT='/path/to/your_domain.crt'
DEPLOY_SSL_SOURCE_KEY='/path/to/your_domain.key'
DEPLOY_SSL_CERT='/etc/nginx/ssl/your_domain.crt'
DEPLOY_SSL_KEY='/etc/nginx/ssl/your_domain.key'

